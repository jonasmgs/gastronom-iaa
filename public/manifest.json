{
  "id": "gastronom-ia-app",
  "name": "Gastronom.IA",
  "short_name": "GastronomIA",
  "description": "Receitas personalizadas com inteligência artificial",
  "start_url": "/",
  "display": "standalone",
  "orientation": "portrait",
  "window_controls_overlay": {
    "display_overlay": true,
    "cookie_label": "gastronom_ia_overlay_state"
  },
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "edge_side_panel": {
    "preferred_width": 400
  },
  "background_color": "#ffffff",
  "theme_color": "#16a34a",
  "lang": "pt-BR",
  "scope": "/",
  "categories": [
    "food",
    "health",
    "lifestyle"
  ],
  "prefer_related_applications": false,
  "periodic_background_sync": {
    "min_interval": 86400,
    "events": ["sync-recipes"]
  },
  "note_taking": {
    "new_note_url": "/edit?new=true",
    "edit_note_url": "/edit?id="
  },
  "share_target": {
    "action": "/share",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "protocol_handlers": [
    {
      "protocol": "gastronom-ia",
      "url": "/?recipe=%s"
    }
  ],
  "file_handlers": [
    {
      "action": "/",
      "accept": {
        "application/json": [".json"],
        "text/plain": [".txt", ".csv"]
      },
      "icons": [
        {
          "src": "/icons/icon-192.png",
          "sizes": "192x192"
        }
      ]
    }
  ],
  "icons": [
    {
      "src": "/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/screenshot1.jpg",
      "sizes": "1080x1920",
      "type": "image/jpeg",
      "form_factor": "narrow",
      "label": "Tela inicial do Gastronom.IA"
    },
    {
      "src": "/screenshots/screenshot2.jpg",
      "sizes": "1080x1920",
      "type": "image/jpeg",
      "form_factor": "narrow",
      "label": "Receita gerada com IA"
    }
  ],
  "shortcuts": [
    {
      "name": "Gerar Receita",
      "short_name": "Receita",
      "description": "Gerar nova receita com IA",
      "url": "/",
      "icons": [
        {
          "src": "/icons/icon-192.png",
          "sizes": "192x192"
        }
      ]
    },
    {
      "name": "Minhas Receitas",
      "short_name": "Receitas",
      "description": "Ver receitas salvas",
      "url": "/recipes",
      "icons": [
        {
          "src": "/icons/icon-192.png",
          "sizes": "192x192"
        }
      ]
    }
  ]
}
