{
  "id": "gastronom-ia-app",
  "name": "Gastronom.IA",
  "short_name": "GastronomIA",
  "description": "Receitas personalizadas com inteligência artificial",
  "start_url": "/",
  "display": "standalone",
  "display_override": [
    "window-controls-overlay",
    "standalone",
    "minimal-ui"
  ],
  "orientation": "portrait",
  "background_color": "#ffffff",
  "theme_color": "#16a34a",
  "lang": "pt-BR",
  "dir": "ltr",
  "scope": "/",
  "iarc_rating_id": "none",
  "categories": [
    "food",
    "health",
    "lifestyle"
  ],
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  "icons": [
    {
      "src": "/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/screenshot1.jpg",
      "sizes": "1080x1920",
      "type": "image/jpeg",
      "form_factor": "narrow",
      "label": "Interface Mobile do Gastronom.IA"
    },
    {
      "src": "/screenshots/screenshot2.jpg",
      "sizes": "1080x1920",
      "type": "image/jpeg",
      "form_factor": "narrow",
      "label": "Interface Mobile do Gastronom.IA"
    }
  ],
  "share_target": {
    "action": "/?share",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+gastronomia",
      "url": "/?recipe=%s"
    }
  ],
  "edge_side_panel": {
    "preferred_width": 400
  },
  "note_taking": {
    "new_note_url": "/?action=new-recipe"
  },
  "shortcuts": [
    {
      "name": "Gerar Receita",
      "short_name": "Gerar",
      "url": "/",
      "icons": [
        {
          "src": "/icons/icon-192.png",
          "sizes": "192x192"
        }
      ]
    },
    {
      "name": "Minhas Receitas",
      "short_name": "Receitas",
      "url": "/recipes",
      "icons": [
        {
          "src": "/icons/icon-192.png",
          "sizes": "192x192"
        }
      ]
    }
  ],
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.gastronomia.app",
      "id": "com.gastronomia.app"
    }
  ],
  "prefer_related_applications": false,
  "scope_extensions": [
    { "origin": "*.vercel.app" },
    { "origin": "https://gastronomia.app" }
  ]
}
